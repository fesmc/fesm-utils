! ====== ESM experiment definitions ======

&ctrl
    experiment      = "ctrl"
    names           = "ref[ts,pr,zs,to,so]", "esm_ref[ts,pr,zs,to,so]", "esm_lgm[ts,pr,zs,to,so]"
    method          = "transient-anom"       ! "transient-anom/abs" or "index-anom/abs"

    ref = "mar_ts", "mar_pr", "mar_zs", "oras5_to", "oras5_so"
    esm_ref = "esm_ts", "esm_zs", "esm_to", "esm_so"
    esm_lgm = "esm_lgm_ts", "esm_lgm_zs", "esm_lgm_to", "esm_lgm_so"
/

&mar_ts
    filename    = "ice_data/{domain}/{grid_name}/{grid_name}_MARv3.11-ERA_monmean_1961-1990.nc"
    meta        = "tas", "K", "K"
    scaling     = 1.0, 0.0
    time_info   = 1990.0, 2019.0, 1.0, 12.0
/

&mar_pr
    filename    = "ice_data/{domain}/{grid_name}/{grid_name}_MARv3.11-ERA_monmean_1961-1990.nc"
    meta        = "sf", "kg m-2 month-1", "mm yr-1"
    scaling     = 0.08333, 0.0
    time_info   = 1990.0, 2019.0, 1.0, 12.0
/

&mar_zs
    filename    = "ice_data/{domain}/{grid_name}/{grid_name}_MARv3.11-ERA_monmean_1961-1990.nc"
    meta        = "zs", "m", "m"
    scaling     = 1.0, 0.0
    time_info   = 2000, 2000, 0, 1
/

&oras5_to
    filename    = "ice_data/{domain}/{grid_name}/ERA-INT-ORAS5/{grid_name}_ORAS5_1990-2019_DETRENDED.nc"
    name        = "thetao_dt", "degrees C", "K"
    unit_scale  = 1.0, 273.15
    time_info   = 1990, 2019, 1, 1
/

&oras5_so
    filename    = "ice_data/{domain}/{grid_name}/ERA-INT-ORAS5/{grid_name}_ORAS5_1990-2019_DETRENDED.nc"
    name        = "so_dt", "PSU", "PSU"
    scaling     = 1.0, 0.0
    time_info   = 1990, 2019, 1, 1
/
