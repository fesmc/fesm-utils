# --- Vendored library trees ---------------------------------------------------
# fftw/, lis/, SHTns/ are frozen upstream snapshots. Their source is already
# committed; everything else is generated — the install prefixes built by
# `make fftw|lis|shtns` (<lib>/<lib>-{serial,omp}) and the in-source autotools
# byproducts (Makefile, .deps/, .libs/, config.log, *.la, ...). Ignore the whole
# containers: git never un-tracks committed files, so the tracked source still
# shows and only build output is hidden (this is what the old /fftw* /lis*
# patterns did before the trees were nested under these dirs).
/fftw/
/lis/
/SHTns/

# Root Makefile is generated by `configme` from the tracked template
# config/Makefile (machine/compiler-specific). Keep it ignored.
/Makefile

# --- autotools configure outputs (generated by ./configure in vendored pkgs) --
config.log
config.status
sht_config.h

# --- runtime outputs from tests / benchmarks (not source) ---------------------
bench_tmp/
logs/
test_wm_*.nc
maps/
maps_cache_test/
maps_cdo_test/

# --- build artifacts ----------------------------------------------------------
*.dSYM
*.mod
*.a
*.o
*.x
__pycache__/

# --- Quarto documentation site (docs/) ---------------------------------------
# Rendered output and Quarto caches are generated; the .qmd sources, committed
# figure PNGs, and the Julia figure env (Project.toml/Manifest.toml) are tracked.
/docs/_site/
/docs/.quarto/

# --- configme / local machinery ----------------------------------------------
.claude
.configme-build.toml
.install.sh
.upgrade.sh
