# Anchored to repo root so they match only the top-level build dirs and not
# nested paths (e.g. the vendored shtns-3.7.5/fftw3/ headers).
/fftw*
/lis*
# SHTns: ignore the build-output prefixes, keep the vendored source (shtns-3.7.5)
/shtns-serial
/shtns-omp
# Only the top-level shtns Makefile is autotools-generated (from Makefile.in).
# Anchored so it does not also match the hand-written source Makefiles under
# shtns-3.7.5/ (SHT/Makefile, doc/Makefile, shtns_jni/.../Makefile).
/shtns-3.7.5/Makefile
# utils/Makefile is generated by `configme` from the tracked template
# utils/config/Makefile (machine/compiler-specific). Keep it ignored.
/utils/Makefile
# autotools configure outputs (generated by ./configure in vendored pkgs)
config.log
config.status
sht_config.h
*.dSYM
*.mod
*.a
*.o
*.x
__pycache__/
.claude
.configme-build.toml
.install.sh
.upgrade.sh

